{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TicketAnalysis",
  "type": "object",
  "properties": {
    "category": {
      "type": "string",
      "enum": ["Billing", "Technical", "Product", "Feature Request", "General"]
    },
    "sentiment_label": {
      "type": "string",
      "enum": ["Positive", "Neutral", "Negative"]
    },
    "sentiment_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "is_escalated": {
      "type": "boolean"
    },
    "suggested_response": {
      "type": "string"
    }
  },
  "required": ["category", "sentiment_label", "sentiment_score", "is_escalated", "suggested_response"]
}
